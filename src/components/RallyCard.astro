---
import type { InferEntrySchema } from 'astro:content';
import StatusBadge from './StatusBadge.astro';
import { dateFull, dateRange } from '../utils/dates';

interface Props {
  data: InferEntrySchema<'events'>;
  slug: string;
}

const { slug, data } = Astro.props;

---

<a href={`/events/${slug}/`} class="rally-card">
    <div class="rally-card__header">
      <StatusBadge status={data.status}/>
    </div>
    <h3 class="rally-card__title">{data.title}</h3>
    {data.date && data.end_date
        ? <p class="rally-card__dates">{dateRange(data.date, data.end_date)}</p>
        : data.date && <p class="rally-card__dates">{dateFull(data.date)}</p>
    }
    <p class="rally-card__location">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        {data.location}
    </p>
    <span class="rally-card__cta">View Details →</span>
</a>
