---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import hero_img from '../assets/ekko_transparent.png';

const allEvents = await getCollection('events');

const activeEvents = allEvents
  .filter(r => !r.data.archived)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
---

<BaseLayout
  title="Upcoming Events"
  description="Upcoming Camp EKKO gatherings for Winnebago Ekko owners — registration, schedules, and community resources."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__inner">
        <div class="page-hero__text">
          <p class="page-hero__eyebrow">Winnebago Ekko Owner Community</p>
          <h1 class="page-hero__title">Camp EKKO</h1>
          <p class="page-hero__sub">Volunteer-run gatherings where Ekko owners come together to camp, learn, and explore.</p>
        </div>
        <div class="page-hero__van">
          <Image src={hero_img} alt="Winnebago Ekko RV in a forest at sunset" loading="eager"/>
        </div>
      </div>
    </div>
  </section>

  <section class="events-section">
    <div class="container">

      {activeEvents.length > 0 ? (
        <>
          <h2 class="section-title">What&#39;s Happening</h2>
          <div class="event-grid">
            {activeEvents.map(event => {
              return (
                <EventCard slug={event.id} data={event.data} />
              );
            })}
          </div>
        </>
      ) : (
        <div class="empty-state">
          <p>No upcoming events at the moment. Check back soon, or browse <a href="/archive/">past events</a>.</p>
        </div>
      )}

    </div>
  </section>

</BaseLayout>
