---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';

const allEvents = await getCollection('events');

const activeEvents = allEvents
  .filter(r => r.data.archived)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

---

<BaseLayout
  title="Past Events"
  description="An archive of past Winnebago Ekko owner events."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__inner">
        <div class="page-hero__text">
          <h1 class="page-hero__title">Past Events</h1>
          <p class="page-hero__sub">A look back at Camp EKKO gatherings.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="events-section">
    <div class="container">

      {activeEvents.length > 0 ? (
        <>
          <div class="event-grid">
            {activeEvents.map(event => {
              return (
                <EventCard slug={event.id} data={event.data} />
              );
            })}
          </div>
        </>
      ) : (
        <div class="empty-state">
          <p>No past events at the moment. Check back soon, or browse <a href="/">current events</a>.</p>
        </div>
      )}

    </div>
  </section>

</BaseLayout>
