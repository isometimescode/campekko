---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RallyCard from '../components/RallyCard.astro';

const allEvents = await getCollection('events');

const activeRallies = allEvents
  .filter(r => r.data.archived)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

---

<BaseLayout
  title="Past Events"
  description="An archive of past Winnebago Ekko owner rallies."
>

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__inner">
        <h1 class="page-hero__title">Archived Events</h1>
        <p class="page-hero__sub">An archive of past Ekko Community events.</p>
      </div>
    </div>
  </section>

  <section class="rallies-section">
    <div class="container">

      {activeRallies.length > 0 ? (
        <>
          <h2 class="section-title">Archived Events</h2>
          <div class="rally-grid">
            {activeRallies.map(rally => {
              return (
                <RallyCard slug={rally.id} data={rally.data} />
              );
            })}
          </div>
        </>
      ) : (
        <div class="empty-state">
          <p>No past events at the moment. Check back soon, or browse <a href="/">current rallies</a>.</p>
        </div>
      )}

    </div>
  </section>

</BaseLayout>
