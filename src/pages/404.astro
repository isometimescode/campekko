---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <section class="not-found">
    <div class="container">
      <div class="not-found__inner">
        <p class="not-found__code">404</p>
        <h1 class="not-found__title">Lost on the trail?</h1>
        <p class="not-found__message">This page doesn't exist — it may have moved or been taken down.</p>
        <div class="not-found__actions">
          <a href="/" class="btn btn--primary btn--large">View Upcoming Events</a>
          <a href="/archive/" class="btn btn--secondary btn--large">Browse Archive</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
